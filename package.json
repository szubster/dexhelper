{
  "name": "dexhelper",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.33.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "data:gen": "node --experimental-strip-types scripts/generate-pokedata.ts",
    "data:gen-maps": "node --experimental-strip-types scripts/generateMapLocations.ts",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "pnpm type-check && pnpm check:biome",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint:biome": "biome lint --error-on-warnings .",
    "format:biome": "biome format .",
    "check:biome": "biome check --error-on-warnings .",
    "type-check": "tsc --noEmit",
    "check:fix": "biome check --write --unsafe .",
    "postinstall": "lefthook install"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.22",
    "@tanstack/react-router-devtools": "^1.166.13",
    "clsx": "^2.1.1",
    "dataloader": "^2.2.3",
    "idb": "^8.0.3",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@argos-ci/playwright": "^6.6.1",
    "@biomejs/biome": "^2.4.12",
    "@codecov/vite-plugin": "^2.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/router-plugin": "^1.167.22",
    "@tsconfig/strictest": "^2.0.8",
    "@tsconfig/vite-react": "^7.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "browserslist": "^4.28.2",
    "bundlemon": "^3.1.0",
    "fake-indexeddb": "^6.2.5",
    "lefthook": "^2.1.5",
    "lightningcss": "^1.32.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "4.2.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
