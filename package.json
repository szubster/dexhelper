{
  "name": "dexhelper",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.33.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "data:gen": "node --experimental-strip-types scripts/generate-pokedata.ts",
    "data:gen-maps": "node --experimental-strip-types scripts/generateMapLocations.ts",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "pnpm type-check && pnpm check:biome && pnpm exec oxlint --type-aware --type-check --import-plugin --promise-plugin . && pnpm knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ct": "vitest --project browser",
    "lint:biome": "biome lint --error-on-warnings .",
    "format:biome": "biome format .",
    "check:biome": "biome check --error-on-warnings .",
    "type-check": "tsc --noEmit",
    "check:fix": "biome check --write --unsafe .",
    "postinstall": "lefthook install",
    "knip": "knip"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-router-devtools": "^1.166.13",
    "clsx": "^2.1.1",
    "dataloader": "^2.2.3",
    "idb": "^8.0.3",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@argos-ci/playwright": "^6.6.4",
    "@biomejs/biome": "^2.4.14",
    "@codecov/vite-plugin": "^2.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@tanstack/router-plugin": "^1.167.33",
    "@tsconfig/strictest": "^2.0.8",
    "@tsconfig/vite-react": "^7.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "browserslist": "^4.28.2",
    "bundlemon": "^3.1.0",
    "fake-indexeddb": "^6.2.5",
    "gray-matter": "^4.0.3",
    "knip": "^6.11.0",
    "lefthook": "^2.1.6",
    "lightningcss": "^1.32.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "playwright": "^1.59.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.5"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "sharp"
    ]
  }
}
