{
  "name": "dexhelper",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.33.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "pnpm type-check && pnpm check:biome",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint:biome": "biome lint --error-on-warnings .",
    "format:biome": "biome format .",
    "check:biome": "biome check --error-on-warnings .",
    "type-check": "tsc --noEmit",
    "check:fix": "biome check --write --unsafe .",
    "postinstall": "lefthook install"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.19",
    "@tanstack/react-router-devtools": "^1.166.13",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@argos-ci/playwright": "^6.6.1",
    "@biomejs/biome": "^2.4.12",
    "@codecov/vite-plugin": "^1.9.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/router-plugin": "^1.167.20",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "bundlemon": "^3.1.0",
    "lefthook": "^2.1.5",
    "pokenode-ts": "^1.20.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
