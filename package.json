    "husky": "^9.1.7",
    "knip": "^6.3.1",
    "lint-staged": "^16.4.0",
    "pokenode-ts": "^1.20.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
