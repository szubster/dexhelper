    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "bundlemon": "^3.1.0",
    "playwright": "^1.59.1",
    "pokenode-ts": "^1.20.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.3.5",
    "tailwindcss": "4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
