---
import { ClientRouter } from 'astro:transitions';
import { AppLayout } from '../components/AppLayout';
import { QueryClientProvider } from '@tanstack/react-query';
import { queryClient } from '../queryClient';
import '../index.css';
import { ClientInit } from '../components/ClientInit';

interface Props {
	title?: string;
}

const { title = 'Retro Save Reader' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="View your Pokemon Gen 1 & 2 save files" />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/dexhelper/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body class="bg-slate-900 text-slate-100 min-h-screen font-sans antialiased overflow-x-hidden">
		<ClientInit client:load />
		<AppLayout client:load currentPath={Astro.url.pathname}>
			<slot />
		</AppLayout>

		<script>
		  // Register Service Worker in production
		  if (import.meta.env.PROD && 'serviceWorker' in navigator) {
			window.addEventListener('load', () => {
			  navigator.serviceWorker.register(`${import.meta.env.BASE_URL}sw.js`).catch(err => {
				console.error('ServiceWorker registration failed: ', err);
			  });
			});
		  }
		</script>
	</body>
</html>
