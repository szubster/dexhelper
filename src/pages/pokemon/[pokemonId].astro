---
import Layout from '../../layouts/Layout.astro';
import { PokemonDetailsView } from '../../components/PokemonDetailsView';
import { fetchPokemonList } from '../../utils/pokemonQueries';

export async function getStaticPaths() {
  const list = await fetchPokemonList();
  // Include valid Pokemon 1-251, plus Egg (253) if needed
  return list.map(p => ({
    params: { pokemonId: p.id.toString() },
    props: { pokemon: p },
  }));
}

const { pokemonId } = Astro.params;
const { pokemon } = Astro.props;
---

<Layout title={`${pokemon.name} - Retro Save Reader`}>
  <PokemonDetailsView client:load pokemonId={pokemon.id} pokemonName={pokemon.name} />
</Layout>
