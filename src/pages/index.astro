---
import Layout from '../layouts/Layout.astro';
import { PokedexView } from '../components/PokedexView';

// Pre-fetch Pokemon list on server during build
import { fetchPokemonList } from '../utils/pokemonQueries';
const pokemonList = await fetchPokemonList();
---

<Layout title="Retro Save Reader">
  <PokedexView client:load pokemonList={pokemonList} />
</Layout>
