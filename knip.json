{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["bundlemon", "gray-matter"],
  "ignore": [".github/scripts/**", "src/test-setup.ts", "scripts/validate-foundry-ids.ts", "src/db/SaveDB.ts"],
  "rules": {
    "files": "warn",
    "exports": "warn",
    "types": "warn",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error"
  }
}
